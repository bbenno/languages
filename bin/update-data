#!/usr/bin/env ruby
# frozen_string_literal: true

require 'net/http'

def download(url, dest)
  File.write("#{__dir__}/../data/#{dest}", Net::HTTP.get(URI.parse(url)))
end

# Download ISO 639-3 data (SIL International)
download 'https://iso639-3.sil.org/sites/iso639-3/files/downloads/iso-639-3.tab', 'iso-639-3.tsv'

# Download macrolanguage mappings (SIL International)
macrolanguages_url = 'https://iso639-3.sil.org/sites/iso639-3/files/downloads/iso-639-3-macrolanguages.tab'
download macrolanguages_url, 'iso-639-3-macrolanguages.tsv'

# Download ISO 639-5 data (Library of Congress)
download 'http://id.loc.gov/vocabulary/iso639-5.tsv', 'iso-639-5.tsv'
